<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Herança do template base de relatório para adicionar seção ETO -->
    <template id="report_ciclos_template_eto_inherit" 
              inherit_id="afr_supervisorio_ciclos.report_ciclos_template">
        
        <!-- Adicionar seção de Parâmetros ETO antes das Estatísticas do Ciclo -->
        <!-- A condição verifica se tem dados ETO E se a categoria contém 'ETO' -->
        <xpath expr="//h5[@class='text-center mb-3'][text()='Estatísticas do Ciclo']" position="before">
            <t t-if="(o.massa_gas_eto or o.concentracao_eto_porcentagem) and o.equipment_category_id and 'ETO' in o.equipment_category_id.name.upper()">
                <!-- Seção de Parâmetros ETO -->
               
                
                <div class="row">
                    <div class="col-2">
                        <strong>Massa Gás: </strong>
                    </div>
                    <div class="col-4">
                        <t t-if="o.massa_gas_eto is not None">
                            <t t-esc="'%.2f' % o.massa_gas_eto"/> Kg
                        </t>
                        <t t-if="o.massa_gas_eto is None">
                            -
                        </t>
                    </div>
                    <div class="col-2">
                        <strong>Concentração ETO: </strong>
                    </div>
                    <div class="col-4">
                        <t t-if="o.concentracao_eto_porcentagem is not None">
                            <t t-esc="'%.1f' % o.concentracao_eto_porcentagem"/>%
                        </t>
                        <t t-if="o.concentracao_eto_porcentagem is None">
                            -
                        </t>
                    </div>
                </div>
                
                <div class="row mb-3 ">
                    <div class="col-2">
                        <strong>Massa ETO: </strong>
                    </div>
                    <div class="col-4">
                        <t t-if="o.massa_eto is not None">
                            <t t-esc="'%.2f' % o.massa_eto"/> Kg
                        </t>
                        <t t-if="o.massa_eto is None">
                            -
                        </t>
                    </div>
                    <div class="col-2">
                        <strong>Concentração na Câmara: </strong>
                    </div>
                    <div class="col-4">
                        <t t-if="o.concentracao_eto_camara is not None">
                            <t t-esc="'%.1f' % o.concentracao_eto_camara"/> mg/L
                        </t>
                        <t t-if="o.concentracao_eto_camara is None">
                            -
                        </t>
                    </div>
                </div>
                
            </t>
        </xpath>

        <!-- Informações complementares: após o gráfico, antes da linha de assinatura -->
        <xpath expr="//div[@class='row mt-5'][div[contains(., 'Garantia de qualidade')]]" position="before">
            <div class="row mt-4 mb-2" t-if="o.informacoes_complementares">
                <div class="col-12 text-justify small" style="white-space: pre-line;" t-field="o.informacoes_complementares"/>
            </div>
        </xpath>
        
    </template>
</odoo>
